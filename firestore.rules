rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =========================
    // HELPERS
    // =========================

    function signedIn() {
      return request.auth != null;
    }

function userDoc() {
  return get(
    /databases/$(database)/documents/users/$(request.auth.uid)
  );
}

function currentUser() {
  return userDoc().data;
}

function userDocExists() {
  return signedIn()
    && exists(
      /databases/$(database)/documents/users/$(request.auth.uid)
    );
}

function isApproved() {
  return userDocExists()
    && currentUser().approved == true
    && currentUser().disabled != true;
}

function isSuperAdmin() {
  return userDocExists()
    && currentUser().approved == true
    && currentUser().disabled != true
    && currentUser().role == "superadmin";
}

function isOrganizer() {
  return userDocExists()
    && currentUser().approved == true
    && currentUser().disabled != true
    && currentUser().role == "organizer";
}

function canCreateEvent() {
  return isSuperAdmin()
    || isOrganizer();
}

function isStringBetween(value, minLength, maxLength) {
  return value is string
    && value.size() >= minLength
    && value.size() <= maxLength;
}

function isStringMax(value, maxLength) {
  return value is string
    && value.size() <= maxLength;
}

function isNullableStringMax(value, maxLength) {
  return value == null
    || (value is string && value.size() <= maxLength);
}

function isFirebaseStorageUrl(value) {
  return value is string
    && value.size() <= 2000
    && value.matches('https://firebasestorage[.]googleapis[.]com/.*');
}

function isEventStoragePath(value, eventId, folder, maxLength) {
  return value is string
    && value.size() <= maxLength
    && value.matches('^events/' + eventId + '/' + folder + '/[^/]+$');
}

    function isEventOwner(eventId) {
      return isApproved()
        && get(
          /databases/$(database)/documents/events/$(eventId)
        ).data.ownerId == request.auth.uid;
    }

    function isEventModerator(eventId) {
      return isApproved()
        && get(
          /databases/$(database)/documents/events/$(eventId)/moderators/$(request.auth.uid)
        ).data.active == true;
    }

    function canModerateEvent(eventId) {
      return isSuperAdmin()
        || isEventOwner(eventId)
        || isEventModerator(eventId);
    }

    function canManageEventModerators(eventId) {
      return isSuperAdmin()
        || isEventOwner(eventId);
    }


    function isPublicActiveEventDoc() {
      return resource.data.active == true
        && resource.data.status == "active"
        && resource.data.expiresAt is number
        && resource.data.expiresAt > request.time.toMillis();
    }

    function isEventOwnerDoc() {
      return isApproved()
        && resource.data.ownerId == request.auth.uid;
    }

    function canReadEventDoc(eventId) {
      return isPublicActiveEventDoc()
        || isSuperAdmin()
        || isEventOwnerDoc()
        || isEventModerator(eventId);
    }

    function canListEventDocs() {
      return isSuperAdmin()
        || (
          isOrganizer()
          && resource.data.ownerId == request.auth.uid
        );
    }

    function eventData(eventId) {
      return get(
        /databases/$(database)/documents/events/$(eventId)
      ).data;
    }

    function eventIsActive(eventId) {
      return eventData(eventId).active == true
        && eventData(eventId).status == "active"
        && eventData(eventId).expiresAt is number
        && eventData(eventId).expiresAt > request.time.toMillis();
    }

    function eventHasPhotoSpace(eventId) {
      return eventData(eventId).photoCount is number
        && eventData(eventId).uploadLimit is number
        && eventData(eventId).photoCount < eventData(eventId).uploadLimit;
    }

    function isValidEventType() {
      return request.resource.data.type in [
        "svadba",
        "rodendan",
        "krstenje",
        "pricest",
        "party",
        "default"
      ];
    }

    function isValidPlanConfig() {
      return
        (
          request.resource.data.plan == "basic"
          && request.resource.data.uploadLimit == 1000
          && request.resource.data.allowOriginals == false
        )
        ||
        (
          request.resource.data.plan == "standard"
          && request.resource.data.uploadLimit == 1200
          && request.resource.data.allowOriginals == true
        )
        ||
        (
          request.resource.data.plan == "premium"
          && request.resource.data.uploadLimit == 1500
          && request.resource.data.allowOriginals == true
        );
    }

    function isValidEventCreate() {
      return request.resource.data.keys().hasOnly([
          "title",
          "type",
          "plan",

          "ownerId",
          "ownerEmail",
          "ownerName",

          "bubbles",
          "texts",

          "active",
          "status",

          "allowOriginals",
          "uploadLimit",

          "photoCount",
          "dedicationCount",
          "likeCount",

          "expiresAt",
          "created"
        ])

        && isStringBetween(request.resource.data.title, 2, 120)

        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.ownerEmail == request.auth.token.email
        && isStringMax(request.resource.data.ownerEmail, 254)
        && isStringMax(request.resource.data.ownerName, 120)

        && isValidEventType()
        && isValidPlanConfig()

        && request.resource.data.bubbles is list
        && request.resource.data.bubbles.size() == 6

        && request.resource.data.texts is map

        && request.resource.data.active == true
        && request.resource.data.status == "active"

        && request.resource.data.photoCount == 0
        && request.resource.data.dedicationCount == 0
        && request.resource.data.likeCount == 0

        && request.resource.data.expiresAt is number
        && request.resource.data.created is number

        && request.resource.data.expiresAt > request.resource.data.created;
    }

    function counterChangedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    function isPhotoCountPlusOne() {
      return counterChangedKeys().hasOnly(["photoCount"])
        && resource.data.photoCount is number
        && request.resource.data.photoCount is number
        && request.resource.data.photoCount == resource.data.photoCount + 1
        && request.resource.data.photoCount <= resource.data.uploadLimit;
    }

    function isPhotoCountMinusOne() {
      return counterChangedKeys().hasOnly(["photoCount"])
        && resource.data.photoCount is number
        && request.resource.data.photoCount is number
        && request.resource.data.photoCount == resource.data.photoCount - 1
        && request.resource.data.photoCount >= 0;
    }

    function isDedicationCountPlusOne() {
      return counterChangedKeys().hasOnly(["dedicationCount"])
        && resource.data.dedicationCount is number
        && request.resource.data.dedicationCount is number
        && request.resource.data.dedicationCount == resource.data.dedicationCount + 1;
    }

    function isLikeCountPlusOne() {
      return counterChangedKeys().hasOnly(["likeCount"])
        && resource.data.likeCount is number
        && request.resource.data.likeCount is number
        && request.resource.data.likeCount == resource.data.likeCount + 1;
    }

    function isOnlyCounterUpdate() {
      return signedIn()
        && (
          isPhotoCountPlusOne()
          || isPhotoCountMinusOne()
          || isDedicationCountPlusOne()
          || isLikeCountPlusOne()
        );
    }

    function isValidUserCreate(userId) {
      return signedIn()
        && request.auth.uid == userId

        && request.resource.data.keys().hasOnly([
          "firstName",
          "lastName",
          "name",
          "email",
          "role",
          "approved",
          "disabled",
          "created"
        ])

        && isStringMax(request.resource.data.firstName, 80)
        && isStringMax(request.resource.data.lastName, 80)
        && isStringMax(request.resource.data.name, 120)

        && request.resource.data.email == request.auth.token.email
        && isStringMax(request.resource.data.email, 254)

        && request.resource.data.role == "organizer"
        && request.resource.data.approved == false
        && request.resource.data.disabled == false

        && request.resource.data.created is number;
    }

    function canCreateModeratorUserDoc() {
      return isSuperAdmin()
        || isOrganizer();
    }

    function isValidModeratorUserCreate() {
      return canCreateModeratorUserDoc()

        && request.resource.data.keys().hasOnly([
          "firstName",
          "lastName",
          "name",
          "email",
          "role",
          "approved",
          "disabled",
          "created"
        ])

        && isStringMax(request.resource.data.firstName, 80)
        && isStringMax(request.resource.data.lastName, 80)
        && isStringMax(request.resource.data.name, 120)
        && isStringMax(request.resource.data.email, 254)

        && request.resource.data.role == "moderator"
        && request.resource.data.approved == true
        && request.resource.data.disabled == false
        && request.resource.data.created is number;
    }

    function isValidModeratorEventAccessCreate(eventId, moderatorUid) {
      return canManageEventModerators(eventId)

        && request.resource.data.keys().hasOnly([
          "email",
          "role",
          "active",
          "created"
        ])
        && isStringMax(request.resource.data.email, 254)
        && request.resource.data.role == "moderator"
        && request.resource.data.active == true
        && request.resource.data.created is number;
    }

    function isValidUploaderUid() {
      return signedIn()
        && isStringMax(request.resource.data.uploaderUid, 128)
        && request.resource.data.uploaderUid == request.auth.uid;
    }

    function isPhotoPublicReadable(eventId) {
      return eventIsActive(eventId)
        && resource.data.visible == true;
    }

    function isPhotoUploader() {
      return signedIn()
        && resource.data.uploaderUid is string
        && resource.data.uploaderUid == request.auth.uid;
    }

    function canReadPhoto(eventId) {
      return isPhotoPublicReadable(eventId)
        || canModerateEvent(eventId)
        || isPhotoUploader();
    }

    function isValidPhotoCreate(eventId) {
      return signedIn()
        && eventIsActive(eventId)
        && eventHasPhotoSpace(eventId)

        && request.resource.data.keys().hasOnly([
          "imageUrl",
          "thumbUrl",
          "path",
          "thumbPath",
          "originalPath",
          "user",
          "userId",
          "uploaderUid",
          "created",
          "likes",
          "visible"
        ])

        && isFirebaseStorageUrl(request.resource.data.imageUrl)
        && isFirebaseStorageUrl(request.resource.data.thumbUrl)
        && isEventStoragePath(request.resource.data.path, eventId, "photos", 500)
        && isEventStoragePath(request.resource.data.thumbPath, eventId, "thumbs", 500)

        && (
          request.resource.data.originalPath == null
          || (
            eventData(eventId).allowOriginals == true
            && isEventStoragePath(request.resource.data.originalPath, eventId, "originals", 500)
          )
        )

        && isStringBetween(request.resource.data.user, 1, 80)
        && isStringBetween(request.resource.data.userId, 1, 160)
        && isValidUploaderUid()

        && request.resource.data.created is number
        && request.resource.data.likes == 0
        && request.resource.data.visible == true;
    }

    function photoChangedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    function likeDocPath(eventId, photoId) {
      return /databases/$(database)/documents/events/$(eventId)/photos/$(photoId)/likes/$(request.auth.uid);
    }

    function isPhotoLikeIncrement(eventId, photoId) {
      return signedIn()
        && photoChangedKeys().hasOnly(["likes"])
        && resource.data.likes is number
        && request.resource.data.likes is number
        && request.resource.data.likes == resource.data.likes + 1
        && !exists(likeDocPath(eventId, photoId))
        && existsAfter(likeDocPath(eventId, photoId));
    }

    function isPhotoVisibilityUpdate() {
      return photoChangedKeys().hasOnly(["visible"])
        && request.resource.data.visible is bool;
    }

    function isValidDedicationCreate(eventId) {
      return signedIn()
        && eventIsActive(eventId)

        && request.resource.data.keys().hasOnly([
          "name",
          "text",
          "userId",
          "uploaderUid",
          "created"
        ])

        && isStringBetween(request.resource.data.name, 1, 80)
        && isStringBetween(request.resource.data.text, 1, 1000)
        && isStringBetween(request.resource.data.userId, 1, 160)
        && isStringMax(request.resource.data.uploaderUid, 128)
        && request.resource.data.uploaderUid == request.auth.uid
        && request.resource.data.created is number;
    }

    function isValidLikeCreate(eventId, likeId) {
      return signedIn()
        && eventIsActive(eventId)
        && likeId == request.auth.uid

        && request.resource.data.keys().hasOnly([
          "created"
        ])

        && request.resource.data.created is number;
    }

    // =========================
    // USERS
    // =========================

match /users/{userId} {

  allow get: if
    signedIn()
    && (
      request.auth.uid == userId
      || isSuperAdmin()
    );

  allow list: if
    isSuperAdmin();

  allow create: if
    isValidUserCreate(userId)
    || isValidModeratorUserCreate();

  allow update: if
    isSuperAdmin();

  allow delete: if false;
}

    // =========================
    // EVENTS
    // =========================

    match /events/{eventId} {

      // Public guests may only fetch a known, active event by ID.
      // They can no longer list all events.
      allow get: if
        canReadEventDoc(eventId);

      // Listing events is limited to superadmin, or to organizer queries
      // constrained to their own ownerId.
      allow list: if
        canListEventDocs();

      allow create: if
        canCreateEvent()
        && isValidEventCreate();

      allow update: if
        isSuperAdmin()
        || isOnlyCounterUpdate();

      allow delete: if
        isSuperAdmin();

      // =====================
      // PHOTOS
      // =====================

      match /photos/{photoId} {

        allow read: if
          canReadPhoto(eventId);

        allow create: if
          isValidPhotoCreate(eventId);

        allow update: if
          isPhotoLikeIncrement(eventId, photoId)
          || (
            isPhotoVisibilityUpdate()
            && canModerateEvent(eventId)
          )
          || (
            isPhotoVisibilityUpdate()
            && signedIn()
            && resource.data.uploaderUid == request.auth.uid
            && request.resource.data.visible == false
          );

        allow delete: if
          isSuperAdmin()
          || isEventOwner(eventId);

        // =====================
        // LIKES
        // =====================

        match /likes/{likeId} {

          allow get: if
            signedIn()
            && (
              likeId == request.auth.uid
              || canModerateEvent(eventId)
            )
            && eventIsActive(eventId);

          allow list: if
            canModerateEvent(eventId);

          allow create: if
            isValidLikeCreate(eventId, likeId);

          allow update: if false;

          allow delete: if
            isSuperAdmin();
        }
      }

      // =====================
      // DEDICATIONS
      // =====================

      match /dedications/{id} {

        // Posvete su privatne: čitaju ih samo superadmin, owner ili moderator eventa.
        allow read: if
          canModerateEvent(eventId);

        allow create: if
          isValidDedicationCreate(eventId);

        allow update: if false;

        allow delete: if
          isSuperAdmin();
      }

      // =====================
      // MODERATORS
      // jedan ili više moderatora po eventu
      // =====================

      match /moderators/{moderatorUid} {

        allow read: if
          canModerateEvent(eventId)
          || (
            signedIn()
            && request.auth.uid == moderatorUid
          );

        allow create: if
          isValidModeratorEventAccessCreate(eventId, moderatorUid);

        allow update: if
          canManageEventModerators(eventId)
          && request.resource.data.keys().hasOnly([
            "email",
            "role",
            "active",
            "created"
          ])
          && isStringMax(request.resource.data.email, 254)
          && request.resource.data.role == "moderator"
          && request.resource.data.active is bool
          && request.resource.data.created is number;

        allow delete: if
          canManageEventModerators(eventId);
      }

      // =====================
      // EVENT USERS
      // ako kasnije koristiš createUser()
      // =====================

      match /users/{userId} {

        allow read: if
          isSuperAdmin()
          || isEventOwner(eventId);

        allow create: if
          signedIn()
          && eventIsActive(eventId)
          && userId == request.auth.uid
          && request.resource.data.keys().hasOnly([
            "name",
            "created"
          ])
          && isStringBetween(request.resource.data.name, 1, 80)
          && request.resource.data.created is number;

        allow update: if false;

        allow delete: if
          isSuperAdmin();
      }
    }
  }
}